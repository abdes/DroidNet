{
  "version": 1,
  "max_in_flight_jobs": 1,
  "output": "H:/projects/DroidNet/projects/Oxygen.Engine/Examples/Content/.cooked",
  "jobs": [
    {
      "id": "material.floor_default",
      "type": "material-descriptor",
      "source": "./floor_default.material.json",
      "name": "floor_default",
      "content_hashing": true
    },
    {
      "id": "material.cube_red",
      "type": "material-descriptor",
      "source": "./cube_red.material.json",
      "name": "cube_red",
      "content_hashing": true
    },
    {
      "id": "geometry.floor",
      "type": "geometry-descriptor",
      "source": "./floor.geometry.json",
