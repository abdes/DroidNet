        "material.floor_default"
      ]
    },
    {
      "id": "geometry.cube",
      "type": "geometry-descriptor",
      "source": "./cube.geometry.json",
      "name": "cube",
      "content_hashing": true,
      "depends_on": [
        "material.cube_red"
      ]
    },
    {
      "id": "scene.vsm_bug1_large_plane",
