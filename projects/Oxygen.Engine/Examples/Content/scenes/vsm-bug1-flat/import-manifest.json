      "source": "./VsmBug1LargePlane.scene.json",
      "name": "VsmBug1LargePlane",
      "content_hashing": true,
      "depends_on": [
        "geometry.floor"
      ]
    },
    {
      "id": "scene.vsm_bug1_large_thin_cube",
      "type": "scene-descriptor",
      "source": "./VsmBug1LargeThinCube.scene.json",
      "name": "VsmBug1LargeThinCube",
      "content_hashing": true,
      "depends_on": [
        "geometry.cube"
      ]
    }
  ]
}
