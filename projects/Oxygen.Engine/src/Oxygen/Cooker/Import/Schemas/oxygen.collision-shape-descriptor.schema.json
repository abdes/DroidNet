{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Oxygen Collision Shape Descriptor",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "shape_type",
        "material_ref"
    ],
    "properties": {
        "$schema": {
            "type": "string"
        },
        "name": {
            "$ref": "#/definitions/identifier"
        },
        "content_hashing": {
            "type": "boolean"
        },
        "virtual_path": {
            "$ref": "#/definitions/canonical_ocshape_path"
        },
        "shape_type": {
            "$ref": "#/definitions/shape_type"
        },
        "material_ref": {
            "$ref": "#/definitions/canonical_opmat_path"
        },
        "payload_ref": {
            "$ref": "#/definitions/canonical_opres_path"
        },
        "local_position": {
            "$ref": "#/definitions/vec3"
        },
        "local_rotation": {
            "$ref": "#/definitions/quat"
        },
        "local_scale": {
            "$ref": "#/definitions/vec3_positive"
        },
        "is_sensor": {
            "type": "boolean"
        },
        "collision_own_layer": {
            "$ref": "#/definitions/u64"
        },
        "collision_target_layers": {
            "$ref": "#/definitions/u64"
        },
        "radius": {
            "type": "number",
            "exclusiveMinimum": 0.0
        },
        "half_height": {
            "type": "number",
            "minimum": 0.0
        },
        "half_extents": {
            "$ref": "#/definitions/vec3_positive"
        },
        "normal": {
            "$ref": "#/definitions/vec3"
        },
        "distance": {
            "type": "number"
        },
        "boundary_mode": {
            "$ref": "#/definitions/world_boundary_mode"
        },
        "limits_min": {
            "$ref": "#/definitions/vec3"
        },
        "limits_max": {
            "$ref": "#/definitions/vec3"
        },
        "children": {
            "$ref": "#/definitions/compound_children"
        }
    },
    "definitions": {
        "identifier": {
            "type": "string",
            "minLength": 1,
            "maxLength": 63,
            "pattern": "^[A-Za-z0-9_][A-Za-z0-9_.-]{0,62}$"
        },
        "shape_type": {
            "enum": [
                "sphere",
                "capsule",
                "box",
                "cylinder",
                "cone",
                "convex_hull",
                "triangle_mesh",
                "height_field",
                "plane",
                "world_boundary",
                "compound"
            ]
        },
        "world_boundary_mode": {
            "enum": [
                "aabb_clamp",
                "plane_set"
            ]
        },
        "u64": {
            "type": "integer"
        },
        "vec3": {
            "type": "array",
            "items": {
                "type": "number"
            },
            "minItems": 3,
            "maxItems": 3
        },
        "quat": {
            "type": "array",
            "items": {
                "type": "number"
            },
            "minItems": 4,
            "maxItems": 4
        },
        "vec3_positive": {
            "type": "array",
            "items": {
                "type": "number",
                "exclusiveMinimum": 0.0
            },
            "minItems": 3,
            "maxItems": 3
        },
        "canonical_ocshape_path": {
            "type": "string",
            "minLength": 1,
            "pattern": "^/(?!.*//)(?!.*\\\\)(?!.*(?:^|/)\\.{1,2}(?:/|$)).+\\.ocshape$"
        },
        "canonical_opmat_path": {
            "type": "string",
            "minLength": 1,
            "pattern": "^/(?!.*//)(?!.*\\\\)(?!.*(?:^|/)\\.{1,2}(?:/|$)).+\\.opmat$"
        },
        "canonical_opres_path": {
            "type": "string",
            "minLength": 1,
            "pattern": "^/(?!.*//)(?!.*\\\\)(?!.*(?:^|/)\\.{1,2}(?:/|$)).+\\.opres$"
        },
        "compound_children": {
            "type": "array",
            "minItems": 1,
            "items": {
                "$ref": "#/definitions/compound_child"
            }
        },
        "compound_child": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "shape_type",
                "local_position",
                "local_rotation",
                "local_scale"
            ],
            "properties": {
                "shape_type": {
                    "$ref": "#/definitions/shape_type"
                },
                "radius": {
                    "type": "number",
                    "exclusiveMinimum": 0.0
                },
                "half_height": {
                    "type": "number",
                    "minimum": 0.0
                },
                "half_extents": {
                    "$ref": "#/definitions/vec3_positive"
                },
                "normal": {
                    "$ref": "#/definitions/vec3"
                },
                "distance": {
                    "type": "number"
                },
                "boundary_mode": {
                    "$ref": "#/definitions/world_boundary_mode"
                },
                "limits_min": {
                    "$ref": "#/definitions/vec3"
                },
                "limits_max": {
                    "$ref": "#/definitions/vec3"
                },
                "payload_ref": {
                    "$ref": "#/definitions/canonical_opres_path"
                },
                "local_position": {
                    "$ref": "#/definitions/vec3"
                },
                "local_rotation": {
                    "$ref": "#/definitions/quat"
                },
                "local_scale": {
                    "$ref": "#/definitions/vec3_positive"
                }
            },
            "allOf": [
                {
                    "if": {
                        "properties": {
                            "shape_type": {
                                "const": "sphere"
                            }
                        },
                        "required": [
                            "shape_type"
                        ]
                    },
                    "then": {
                        "required": [
                            "radius"
                        ],
                        "not": {
                            "required": [
                                "payload_ref"
                            ]
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "shape_type": {
                                "const": "capsule"
                            }
                        },
                        "required": [
                            "shape_type"
                        ]
                    },
                    "then": {
                        "required": [
                            "radius",
                            "half_height"
                        ],
                        "not": {
                            "required": [
                                "payload_ref"
                            ]
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "shape_type": {
                                "const": "box"
                            }
                        },
                        "required": [
                            "shape_type"
                        ]
                    },
                    "then": {
                        "required": [
                            "half_extents"
                        ],
                        "not": {
                            "required": [
                                "payload_ref"
                            ]
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "shape_type": {
                                "const": "cylinder"
                            }
                        },
                        "required": [
                            "shape_type"
                        ]
                    },
                    "then": {
                        "required": [
                            "radius",
                            "half_height"
                        ],
                        "not": {
                            "required": [
                                "payload_ref"
                            ]
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "shape_type": {
                                "const": "cone"
                            }
                        },
                        "required": [
                            "shape_type"
                        ]
                    },
                    "then": {
                        "required": [
                            "radius",
                            "half_height"
                        ],
                        "not": {
                            "required": [
                                "payload_ref"
                            ]
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "shape_type": {
                                "const": "plane"
                            }
                        },
                        "required": [
                            "shape_type"
                        ]
                    },
                    "then": {
                        "required": [
                            "normal",
                            "distance"
                        ],
                        "not": {
                            "required": [
                                "payload_ref"
                            ]
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "shape_type": {
                                "const": "world_boundary"
                            }
                        },
                        "required": [
                            "shape_type"
                        ]
                    },
                    "then": {
                        "required": [
                            "boundary_mode",
                            "limits_min",
                            "limits_max"
                        ],
                        "not": {
                            "required": [
                                "payload_ref"
                            ]
                        }
                    }
                }
            ]
        }
    },
    "allOf": [
        {
            "if": {
                "properties": {
                    "shape_type": {
                        "const": "sphere"
                    }
                },
                "required": [
                    "shape_type"
                ]
            },
            "then": {
                "required": [
                    "radius"
                ],
                "not": {
                    "required": [
                        "payload_ref"
                    ]
                }
            }
        },
        {
            "if": {
                "properties": {
                    "shape_type": {
                        "const": "capsule"
                    }
                },
                "required": [
                    "shape_type"
                ]
            },
            "then": {
                "required": [
                    "radius",
                    "half_height"
                ],
                "not": {
                    "required": [
                        "payload_ref"
                    ]
                }
            }
        },
        {
            "if": {
                "properties": {
                    "shape_type": {
                        "const": "box"
                    }
                },
                "required": [
                    "shape_type"
                ]
            },
            "then": {
                "required": [
                    "half_extents"
                ],
                "not": {
                    "required": [
                        "payload_ref"
                    ]
                }
            }
        },
        {
            "if": {
                "properties": {
                    "shape_type": {
                        "const": "cylinder"
                    }
                },
                "required": [
                    "shape_type"
                ]
            },
            "then": {
                "required": [
                    "radius",
                    "half_height"
                ],
                "not": {
                    "required": [
                        "payload_ref"
                    ]
                }
            }
        },
        {
            "if": {
                "properties": {
                    "shape_type": {
                        "const": "cone"
                    }
                },
                "required": [
                    "shape_type"
                ]
            },
            "then": {
                "required": [
                    "radius",
                    "half_height"
                ],
                "not": {
                    "required": [
                        "payload_ref"
                    ]
                }
            }
        },
        {
            "if": {
                "properties": {
                    "shape_type": {
                        "const": "plane"
                    }
                },
                "required": [
                    "shape_type"
                ]
            },
            "then": {
                "required": [
                    "normal",
                    "distance"
                ],
                "not": {
                    "required": [
                        "payload_ref"
                    ]
                }
            }
        },
        {
            "if": {
                "properties": {
                    "shape_type": {
                        "const": "world_boundary"
                    }
                },
                "required": [
                    "shape_type"
                ]
            },
            "then": {
                "required": [
                    "boundary_mode",
                    "limits_min",
                    "limits_max"
                ],
                "not": {
                    "required": [
                        "payload_ref"
                    ]
                }
            }
        },
        {
            "if": {
                "properties": {
                    "shape_type": {
                        "const": "compound"
                    }
                },
                "required": [
                    "shape_type"
                ]
            },
            "then": {
                "required": [
                    "children"
                ],
                "not": {
                    "required": [
                        "payload_ref"
                    ]
                }
            }
        }
    ]
}
