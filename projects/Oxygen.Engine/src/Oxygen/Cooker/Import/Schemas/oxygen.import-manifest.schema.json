{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Oxygen Import Manifest",
    "type": "object",
    "additionalProperties": false,
    "properties": {
        "$schema": {
            "type": "string",
            "description": "Optional self-reference to this schema file."
        },
        "version": {
            "type": "integer",
            "const": 1
        },
        "thread_pool_size": {
            "type": "integer",
            "minimum": 1
        },
        "max_in_flight_jobs": {
            "type": "integer",
            "minimum": 1
        },
        "concurrency": {
            "type": "object",
            "properties": {
                "texture": {
                    "$ref": "#/definitions/concurrency_item"
                },
                "buffer": {
                    "$ref": "#/definitions/concurrency_item"
                },
                "material": {
                    "$ref": "#/definitions/concurrency_item"
                },
                "mesh_build": {
                    "$ref": "#/definitions/concurrency_item"
                },
                "geometry": {
                    "$ref": "#/definitions/concurrency_item"
                },
                "scene": {
                    "$ref": "#/definitions/concurrency_item"
                }
            },
            "additionalProperties": false
        },
        "defaults": {
            "$ref": "#/definitions/defaults_settings"
        },
        "layout": {
            "$ref": "#/definitions/layout_settings"
        },
        "output": {
            "type": "string"
        },
        "jobs": {
            "type": "array",
            "items": {
                "$ref": "#/definitions/job_item"
            }
        }
    },
    "required": [
        "jobs"
    ],
    "definitions": {
        "concurrency_item": {
            "type": "object",
            "properties": {
                "workers": {
                    "type": "integer",
                    "minimum": 1
                },
                "queue_capacity": {
                    "type": "integer",
                    "minimum": 1
                }
            },
            "required": [
                "workers",
                "queue_capacity"
            ],
            "additionalProperties": false
        },
        "job_item": {
            "type": "object",
            "allOf": [
                {
                    "$ref": "#/definitions/job_settings"
                },
                {
                    "required": [
                        "type"
                    ]
                },
                {
                    "if": {
                        "properties": {
                            "type": {
                                "const": "texture-descriptor"
                            }
                        }
                    },
                    "then": {
                        "propertyNames": {
                            "enum": [
                                "id",
                                "depends_on",
                                "type",
                                "source",
                                "sources",
                                "output",
                                "name",
                                "verbose",
                                "intent",
                                "color_space",
                                "output_format",
                                "data_format",
                                "preset",
                                "mip_policy",
                                "mip_filter",
                                "mip_filter_space",
                                "bc7_quality",
                                "packing_policy",
                                "cube_layout",
                                "hdr_handling",
                                "exposure_ev",
                                "max_mips",
                                "cube_face_size",
                                "flip_y",
                                "flip_normal_green",
                                "renormalize",
                                "bake_hdr",
                                "force_rgba",
                                "cubemap",
                                "equirect_to_cube",
                                "content_hashing"
                            ]
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "type": {
                                "const": "buffer-container"
                            }
                        }
                    },
                    "then": {
                        "propertyNames": {
                            "enum": [
                                "id",
                                "depends_on",
                                "type",
                                "source",
                                "output",
                                "name",
                                "content_hashing"
                            ]
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "type": {
                                "const": "material-descriptor"
                            }
                        }
                    },
                    "then": {
                        "propertyNames": {
                            "enum": [
                                "id",
                                "depends_on",
                                "type",
                                "source",
                                "output",
                                "name",
                                "content_hashing"
                            ]
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "type": {
                                "const": "physics-material-descriptor"
                            }
                        }
                    },
                    "then": {
                        "propertyNames": {
                            "enum": [
                                "id",
                                "depends_on",
                                "type",
                                "source",
                                "output",
                                "name",
                                "content_hashing"
                            ]
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "type": {
                                "const": "collision-shape-descriptor"
                            }
                        }
                    },
                    "then": {
                        "propertyNames": {
                            "enum": [
                                "id",
                                "depends_on",
                                "type",
                                "source",
                                "output",
                                "name",
                                "content_hashing"
                            ]
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "type": {
                                "const": "geometry-descriptor"
                            }
                        }
                    },
                    "then": {
                        "propertyNames": {
                            "enum": [
                                "id",
                                "depends_on",
                                "type",
                                "source",
                                "output",
                                "name",
                                "content_hashing"
                            ]
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "type": {
                                "const": "scene-descriptor"
                            }
                        }
                    },
                    "then": {
                        "propertyNames": {
                            "enum": [
                                "id",
                                "depends_on",
                                "type",
                                "source",
                                "output",
                                "name",
                                "content_hashing"
                            ]
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "type": {
                                "enum": [
                                    "script-sidecar",
                                    "physics-sidecar"
                                ]
                            }
                        }
                    },
                    "then": {
                        "allOf": [
                            {
                                "oneOf": [
                                    {
                                        "required": [
                                            "source",
                                            "target_scene_virtual_path"
                                        ]
                                    },
                                    {
                                        "required": [
                                            "bindings",
                                            "target_scene_virtual_path"
                                        ]
                                    }
                                ]
                            }
                        ]
                    },
                    "else": {
                        "required": [
                            "source"
                        ]
                    }
                },
                {
                    "if": {
                        "properties": {
                            "type": {
                                "const": "script-sidecar"
                            }
                        }
                    },
                    "then": {
                        "properties": {
                            "bindings": {
                                "type": "array",
                                "items": {
                                    "type": "object"
                                }
                            }
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "type": {
                                "const": "physics-sidecar"
                            }
                        }
                    },
                    "then": {
                        "properties": {
                            "bindings": {
                                "type": "object"
                            }
                        },
                        "propertyNames": {
                            "enum": [
                                "id",
                                "depends_on",
                                "type",
                                "source",
                                "bindings",
                                "target_scene_virtual_path",
                                "output",
                                "name",
                                "verbose",
                                "content_hashing"
                            ]
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "type": {
                                "const": "input"
                            }
                        }
                    },
                    "then": {
                        "required": [
                            "id",
                            "source"
                        ],
                        "propertyNames": {
                            "enum": [
                                "id",
                                "type",
                                "source",
                                "depends_on",
                                "output"
                            ]
                        }
                    }
                }
            ]
        },
        "defaults_settings": {
            "type": "object",
            "properties": {
                "texture": {
                    "$ref": "#/definitions/texture_settings"
                },
                "scene": {
