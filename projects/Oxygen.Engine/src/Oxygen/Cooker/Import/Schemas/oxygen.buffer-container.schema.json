{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Oxygen Buffer Container Descriptor",
    "type": "object",
    "additionalProperties": false,
    "properties": {
        "$schema": {
            "type": "string"
        },
        "name": {
            "type": "string",
            "minLength": 1
        },
        "content_hashing": {
            "type": "boolean"
        },
        "buffers": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "source": {
                        "type": "string",
                        "minLength": 1
                    },
                    "virtual_path": {
                        "type": "string",
                        "minLength": 1,
                        "pattern": "^/(?!.*//)(?!.*\\\\)(?!.*(?:^|/)\\.{1,2}(?:/|$)).+\\.obuf$"
                    },
                    "usage_flags": {
                        "type": "integer",
                        "minimum": 0
                    },
                    "element_stride": {
                        "type": "integer",
                        "minimum": 0
                    },
                    "element_format": {
                        "type": "integer",
                        "minimum": 0,
                        "maximum": 255
                    },
                    "alignment": {
                        "type": "integer",
                        "minimum": 1
                    },
                    "content_hash": {
                        "type": "integer",
                        "minimum": 0
                    }
                },
                "required": [
                    "source",
                    "virtual_path"
                ],
                "allOf": [
                    {
                        "if": {
                            "properties": {
                                "element_format": {
                                    "type": "integer",
                                    "minimum": 1
                                }
                            },
                            "required": [
                                "element_format"
                            ]
                        },
                        "then": {
                            "properties": {
                                "element_stride": {
                                    "type": "integer",
                                    "const": 0
                                }
                            }
                        }
                    },
                    {
                        "if": {
                            "properties": {
                                "element_stride": {
                                    "type": "integer",
                                    "minimum": 1
                                }
                            },
                            "required": [
                                "element_stride"
                            ]
                        },
                        "then": {
                            "properties": {
                                "element_format": {
                                    "type": "integer",
                                    "maximum": 0
                                }
                            }
                        }
                    },
                    {
                        "if": {
                            "properties": {
                                "element_stride": {
                                    "type": "integer",
                                    "const": 0
                                }
                            },
                            "required": [
                                "element_stride"
                            ]
                        },
                        "then": {
                            "properties": {
                                "element_format": {
                                    "type": "integer",
                                    "minimum": 1
                                }
                            },
                            "required": [
                                "element_format"
                            ]
                        }
                    }
                ]
            }
        }
    },
    "required": [
        "buffers"
    ]
}
