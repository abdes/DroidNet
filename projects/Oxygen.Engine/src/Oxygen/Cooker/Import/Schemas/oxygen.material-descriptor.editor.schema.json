{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://oxygen.editor/schemas/oxygen.material-descriptor.editor.schema.json",
    "$ref": "oxygen.material-descriptor.schema.json",
    "title": "Material Descriptor (editor overlay)",
    "description": "Editor metadata layered on top of the engine material descriptor schema. Adds x-editor-* annotations only; introduces no constraints. The authored material remains a single JSON document validated by the engine schema.",
    "properties": {
        "name": {
            "x-editor-label": "Name",
            "x-editor-group": "Identity",
            "x-editor-order": 0,
            "x-editor-renderer": "text-readonly",
            "x-editor-tooltip": "Display name of the material asset."
        },
        "domain": {
            "x-editor-label": "Domain",
            "x-editor-group": "Identity",
            "x-editor-order": 1,
            "x-editor-renderer": "enum-dropdown",
            "x-editor-tooltip": "Material domain. Drives the cooking shader permutation set."
        },
        "alpha_mode": {
            "x-editor-label": "Alpha Mode",
            "x-editor-group": "Identity",
            "x-editor-order": 2,
            "x-editor-renderer": "enum-dropdown",
            "x-editor-tooltip": "Alpha-blending mode. 'masked' uses the alpha cutoff threshold."
        },
        "orm_policy": {
            "x-editor-label": "ORM Packing",
            "x-editor-group": "Identity",
            "x-editor-order": 3,
            "x-editor-renderer": "enum-dropdown",
            "x-editor-advanced": true,
            "x-editor-tooltip": "Occlusion/Roughness/Metalness packing policy used by the cooker."
        },
        "content_hashing": {
            "x-editor-label": "Content Hashing",
            "x-editor-group": "Identity",
            "x-editor-order": 4,
            "x-editor-renderer": "checkbox",
            "x-editor-advanced": true,
            "x-editor-tooltip": "Enable content-based hashing for shader and material assets."
        },
        "parameters": {
            "x-editor-label": "Parameters",
            "x-editor-group": "Surface",
            "x-editor-order": 10,
            "x-editor-renderer": "section",
            "properties": {
                "base_color": {
                    "x-editor-label": "Base Color",
                    "x-editor-group": "Surface",
                    "x-editor-order": 0,
                    "x-editor-renderer": "color-rgba",
                    "x-editor-tooltip": "Base color factor (RGBA). Multiplied by the base color texture, if present."
                },
                "metalness": {
                    "x-editor-label": "Metalness",
                    "x-editor-group": "Surface",
                    "x-editor-order": 1,
                    "x-editor-renderer": "slider",
                    "x-editor-step": 0.01,
                    "x-editor-soft-min": 0.0,
                    "x-editor-soft-max": 1.0,
                    "x-editor-tooltip": "Metalness factor. 0 = dielectric, 1 = metallic."
                },
                "roughness": {
                    "x-editor-label": "Roughness",
                    "x-editor-group": "Surface",
                    "x-editor-order": 2,
                    "x-editor-renderer": "slider",
                    "x-editor-step": 0.01,
                    "x-editor-soft-min": 0.0,
                    "x-editor-soft-max": 1.0,
                    "x-editor-tooltip": "Microfacet roughness. 0 = mirror, 1 = fully diffuse."
                },
                "ambient_occlusion": {
                    "x-editor-label": "Ambient Occlusion",
                    "x-editor-group": "Surface",
                    "x-editor-order": 3,
                    "x-editor-renderer": "slider",
                    "x-editor-step": 0.01,
                    "x-editor-soft-min": 0.0,
                    "x-editor-soft-max": 1.0,
                    "x-editor-tooltip": "Strength of the ambient occlusion contribution."
                },
                "normal_scale": {
                    "x-editor-label": "Normal Scale",
                    "x-editor-group": "Surface",
                    "x-editor-order": 4,
                    "x-editor-renderer": "numberbox",
                    "x-editor-step": 0.01,
                    "x-editor-soft-min": 0.0,
                    "x-editor-soft-max": 4.0,
                    "x-editor-tooltip": "Scale applied to the sampled tangent-space normal."
                },
                "emissive_factor": {
                    "x-editor-label": "Emissive",
                    "x-editor-group": "Surface",
                    "x-editor-order": 5,
                    "x-editor-renderer": "color-rgb-hdr",
                    "x-editor-tooltip": "Emissive factor (HDR RGB). Multiplied by the emissive texture, if present."
                },
                "alpha_cutoff": {
                    "x-editor-label": "Alpha Cutoff",
                    "x-editor-group": "Surface",
                    "x-editor-order": 6,
                    "x-editor-renderer": "slider",
                    "x-editor-step": 0.01,
                    "x-editor-soft-min": 0.0,
                    "x-editor-soft-max": 1.0,
                    "x-editor-tooltip": "Alpha threshold used when alpha mode is 'masked'."
                },
                "ior": {
                    "x-editor-label": "Index of Refraction",
                    "x-editor-group": "Advanced",
                    "x-editor-order": 7,
                    "x-editor-renderer": "numberbox",
                    "x-editor-step": 0.01,
                    "x-editor-soft-min": 1.0,
                    "x-editor-soft-max": 3.0,
                    "x-editor-advanced": true,
                    "x-editor-tooltip": "Index of refraction (>= 1.0). Used by transmission and specular models."
                },
                "specular_factor": {
                    "x-editor-label": "Specular",
                    "x-editor-group": "Advanced",
                    "x-editor-order": 8,
                    "x-editor-renderer": "slider",
                    "x-editor-step": 0.01,
                    "x-editor-soft-min": 0.0,
                    "x-editor-soft-max": 1.0,
                    "x-editor-advanced": true,
                    "x-editor-tooltip": "Dielectric specular reflection factor."
                },
                "sheen_color_factor": {
                    "x-editor-label": "Sheen Color",
                    "x-editor-group": "Advanced",
                    "x-editor-order": 9,
                    "x-editor-renderer": "color-rgb",
                    "x-editor-advanced": true,
                    "x-editor-tooltip": "Sheen color factor for cloth-like materials."
                },
                "clearcoat_factor": {
                    "x-editor-label": "Clearcoat",
                    "x-editor-group": "Advanced",
                    "x-editor-order": 10,
                    "x-editor-renderer": "slider",
                    "x-editor-step": 0.01,
                    "x-editor-soft-min": 0.0,
                    "x-editor-soft-max": 1.0,
                    "x-editor-advanced": true,
                    "x-editor-tooltip": "Clearcoat layer intensity."
                },
                "clearcoat_roughness": {
                    "x-editor-label": "Clearcoat Roughness",
                    "x-editor-group": "Advanced",
                    "x-editor-order": 11,
                    "x-editor-renderer": "slider",
                    "x-editor-step": 0.01,
                    "x-editor-soft-min": 0.0,
                    "x-editor-soft-max": 1.0,
                    "x-editor-advanced": true,
                    "x-editor-tooltip": "Roughness of the clearcoat layer."
                },
                "transmission_factor": {
                    "x-editor-label": "Transmission",
                    "x-editor-group": "Advanced",
                    "x-editor-order": 12,
                    "x-editor-renderer": "slider",
                    "x-editor-step": 0.01,
                    "x-editor-soft-min": 0.0,
                    "x-editor-soft-max": 1.0,
                    "x-editor-advanced": true,
                    "x-editor-tooltip": "Light transmission factor."
                },
                "thickness_factor": {
                    "x-editor-label": "Thickness",
                    "x-editor-group": "Advanced",
                    "x-editor-order": 13,
                    "x-editor-renderer": "numberbox",
                    "x-editor-step": 0.01,
                    "x-editor-soft-min": 0.0,
                    "x-editor-advanced": true,
                    "x-editor-tooltip": "Volume thickness used for transmission and attenuation."
                },
                "attenuation_color": {
                    "x-editor-label": "Attenuation Color",
                    "x-editor-group": "Advanced",
                    "x-editor-order": 14,
                    "x-editor-renderer": "color-rgb",
                    "x-editor-advanced": true,
                    "x-editor-tooltip": "Volumetric attenuation color."
                },
                "attenuation_distance": {
                    "x-editor-label": "Attenuation Distance",
                    "x-editor-group": "Advanced",
                    "x-editor-order": 15,
                    "x-editor-renderer": "numberbox",
                    "x-editor-step": 0.01,
                    "x-editor-soft-min": 0.0,
                    "x-editor-advanced": true,
                    "x-editor-tooltip": "Distance at which the attenuation color is reached."
                },
                "double_sided": {
                    "x-editor-label": "Double Sided",
                    "x-editor-group": "Surface",
                    "x-editor-order": 20,
                    "x-editor-renderer": "checkbox",
                    "x-editor-tooltip": "Disable back-face culling for this material."
                },
                "unlit": {
                    "x-editor-label": "Unlit",
                    "x-editor-group": "Surface",
                    "x-editor-order": 21,
                    "x-editor-renderer": "checkbox",
                    "x-editor-tooltip": "Skip lighting; output base color directly."
                },
                "roughness_as_glossiness": {
                    "x-editor-label": "Roughness Is Glossiness",
                    "x-editor-group": "Advanced",
                    "x-editor-order": 22,
                    "x-editor-renderer": "checkbox",
                    "x-editor-advanced": true,
                    "x-editor-tooltip": "Interpret the roughness channel as glossiness (1 - roughness)."
                }
            }
        },
        "textures": {
            "x-editor-label": "Textures",
            "x-editor-group": "Textures",
            "x-editor-order": 20,
            "x-editor-renderer": "section",
            "properties": {
                "base_color": {
                    "x-editor-label": "Base Color",
                    "x-editor-group": "Textures",
                    "x-editor-order": 0,
                    "x-editor-renderer": "asset-picker",
                    "x-editor-tooltip": "Base color (albedo) texture."
                },
                "normal": {
                    "x-editor-label": "Normal",
                    "x-editor-group": "Textures",
                    "x-editor-order": 1,
                    "x-editor-renderer": "asset-picker",
                    "x-editor-tooltip": "Tangent-space normal map."
                },
                "metallic": {
                    "x-editor-label": "Metallic",
                    "x-editor-group": "Textures",
                    "x-editor-order": 2,
                    "x-editor-renderer": "asset-picker",
                    "x-editor-tooltip": "Metallic mask."
                },
                "roughness": {
                    "x-editor-label": "Roughness",
                    "x-editor-group": "Textures",
                    "x-editor-order": 3,
                    "x-editor-renderer": "asset-picker",
                    "x-editor-tooltip": "Roughness mask."
                },
                "ambient_occlusion": {
                    "x-editor-label": "Ambient Occlusion",
                    "x-editor-group": "Textures",
                    "x-editor-order": 4,
                    "x-editor-renderer": "asset-picker",
                    "x-editor-tooltip": "Ambient occlusion mask."
                },
                "emissive": {
                    "x-editor-label": "Emissive",
                    "x-editor-group": "Textures",
                    "x-editor-order": 5,
                    "x-editor-renderer": "asset-picker",
                    "x-editor-tooltip": "Emissive texture."
                },
                "specular": {
                    "x-editor-label": "Specular",
                    "x-editor-group": "Textures",
                    "x-editor-order": 6,
                    "x-editor-renderer": "asset-picker",
                    "x-editor-advanced": true,
                    "x-editor-tooltip": "Dielectric specular mask."
                },
                "sheen_color": {
                    "x-editor-label": "Sheen Color",
                    "x-editor-group": "Textures",
                    "x-editor-order": 7,
                    "x-editor-renderer": "asset-picker",
                    "x-editor-advanced": true,
                    "x-editor-tooltip": "Sheen color texture."
                },
                "clearcoat": {
                    "x-editor-label": "Clearcoat",
                    "x-editor-group": "Textures",
                    "x-editor-order": 8,
                    "x-editor-renderer": "asset-picker",
                    "x-editor-advanced": true,
                    "x-editor-tooltip": "Clearcoat intensity texture."
                },
                "clearcoat_normal": {
                    "x-editor-label": "Clearcoat Normal",
                    "x-editor-group": "Textures",
                    "x-editor-order": 9,
                    "x-editor-renderer": "asset-picker",
                    "x-editor-advanced": true,
                    "x-editor-tooltip": "Clearcoat normal map."
                },
                "transmission": {
                    "x-editor-label": "Transmission",
                    "x-editor-group": "Textures",
                    "x-editor-order": 10,
                    "x-editor-renderer": "asset-picker",
                    "x-editor-advanced": true,
                    "x-editor-tooltip": "Transmission factor texture."
                },
                "thickness": {
                    "x-editor-label": "Thickness",
                    "x-editor-group": "Textures",
                    "x-editor-order": 11,
                    "x-editor-renderer": "asset-picker",
                    "x-editor-advanced": true,
                    "x-editor-tooltip": "Volume thickness texture."
                }
            }
        },
        "shaders": {
            "x-editor-label": "Shaders",
            "x-editor-group": "Shaders",
            "x-editor-order": 30,
            "x-editor-renderer": "section",
            "x-editor-advanced": true,
            "x-editor-tooltip": "Custom shader stage overrides."
        }
    }
}
