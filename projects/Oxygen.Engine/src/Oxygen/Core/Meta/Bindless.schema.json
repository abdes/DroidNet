{
  "$id": "https://example.org/bindless/Spec.schema.json",
  "x-oxygen-schema-version": "2.0.0",
  "title": "BindlessSpec",
  "description": "JSON Schema for the Oxygen bindless authored model.",
  "type": "object",
  "required": [
    "meta",
    "defaults",
    "abi",
    "backends"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "properties": {
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "description": {
          "type": "string"
        }
      },
      "required": [
        "version"
      ],
      "additionalProperties": false
    },
    "defaults": {
      "type": "object",
      "properties": {
        "invalid_index": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": [
        "invalid_index"
      ],
      "additionalProperties": false
    },
    "abi": {
      "type": "object",
      "required": [
        "index_spaces",
        "domains"
      ],
      "properties": {
        "index_spaces": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "id"
            ],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
              }
            },
            "additionalProperties": false
          }
        },
        "domains": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "id",
              "name",
              "index_space",
              "shader_index_base",
              "capacity",
              "shader_access_class",
              "view_types"
            ],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
              },
              "name": {
                "type": "string",
                "minLength": 1
              },
              "index_space": {
                "type": "string",
                "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
              },
              "shader_index_base": {
                "type": "integer",
                "minimum": 0
              },
              "capacity": {
                "type": "integer",
                "minimum": 1
              },
              "shader_access_class": {
                "type": "string",
                "enum": [
                  "buffer_srv",
                  "buffer_uav",
                  "texture_srv",
                  "texture_uav",
                  "constant_buffer",
                  "sampler",
                  "ray_tracing_accel_structure_srv"
                ]
              },
              "view_types": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "enum": [
                    "Texture_SRV",
                    "Texture_UAV",
                    "TypedBuffer_SRV",
                    "TypedBuffer_UAV",
                    "StructuredBuffer_SRV",
                    "StructuredBuffer_UAV",
                    "RawBuffer_SRV",
                    "RawBuffer_UAV",
                    "ConstantBuffer",
                    "Sampler",
                    "SamplerFeedbackTexture_UAV",
                    "RayTracingAccelStructure"
                  ]
                }
              },
              "comment": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "backends": {
      "type": "object",
      "required": [
        "d3d12",
        "vulkan"
      ],
      "properties": {
        "d3d12": {
          "$ref": "#/$defs/d3d12_backend"
        },
        "vulkan": {
          "$ref": "#/$defs/vulkan_backend"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "shader_visibility": {
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "ALL",
            "VERTEX",
            "HULL",
            "DOMAIN",
            "GEOMETRY",
            "PIXEL",
            "VS",
            "HS",
            "DS",
            "GS",
            "PS"
          ]
        },
        {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "ALL",
              "VERTEX",
              "HULL",
              "DOMAIN",
              "GEOMETRY",
              "PIXEL",
              "VS",
              "HS",
              "DS",
              "GS",
              "PS"
            ]
          },
          "minItems": 1
        }
      ]
    },
    "vulkan_stage_flags": {
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "ALL",
            "VERTEX",
            "TESSELLATION_CONTROL",
            "TESSELLATION_EVALUATION",
            "GEOMETRY",
            "FRAGMENT",
            "COMPUTE"
          ]
        },
        {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "ALL",
              "VERTEX",
              "TESSELLATION_CONTROL",
              "TESSELLATION_EVALUATION",
              "GEOMETRY",
              "FRAGMENT",
              "COMPUTE"
            ]
          },
          "minItems": 1
        }
      ]
    },
    "d3d12_heap": {
      "type": "object",
      "required": [
        "id",
        "type",
        "shader_visible",
        "capacity",
        "base_index",
        "allow_growth"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "CBV_SRV_UAV",
            "SAMPLER",
            "RTV",
            "DSV",
            "Other"
          ]
        },
        "shader_visible": {
          "type": "boolean"
        },
        "capacity": {
          "type": "integer",
          "minimum": 1
        },
        "base_index": {
          "type": "integer",
          "minimum": 0
        },
        "allow_growth": {
          "type": "boolean"
        },
        "growth_factor": {
          "type": "number",
          "exclusiveMinimum": 1.0
        },
        "max_growth_iterations": {
          "type": "integer",
          "minimum": 0
        },
        "debug_name": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "d3d12_table": {
      "type": "object",
      "required": [
        "id",
        "descriptor_kind",
        "heap",
        "shader_register",
        "register_space"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
        },
        "descriptor_kind": {
          "type": "string",
          "enum": [
            "SRV",
            "UAV",
            "CBV",
            "SAMPLER"
          ]
        },
        "heap": {
          "type": "string"
        },
        "shader_register": {
          "type": "string",
          "pattern": "^[tbsu]\\d+$"
        },
        "register_space": {
          "type": "string",
          "pattern": "^space\\d+$"
        },
        "unbounded": {
          "type": "boolean"
        },
        "descriptor_count": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "oneOf": [
            {
              "properties": {
                "unbounded": {
                  "const": true
                }
              },
              "required": [
                "unbounded"
              ]
            },
            {
              "required": [
                "descriptor_count"
              ]
            }
          ]
        }
      ]
    },
    "d3d12_domain_realization": {
      "type": "object",
      "required": [
        "domain",
        "table",
        "heap_local_base"
      ],
      "properties": {
        "domain": {
          "type": "string"
        },
        "table": {
          "type": "string"
        },
        "heap_local_base": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "d3d12_root_param": {
      "type": "object",
      "required": [
        "type",
        "id",
        "index",
        "visibility"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "descriptor_table",
            "cbv",
            "root_constants"
          ]
        },
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
        },
        "index": {
          "type": "integer",
          "minimum": 0
        },
        "visibility": {
          "$ref": "#/$defs/shader_visibility"
        },
        "table": {
          "type": "string"
        },
        "shader_register": {
          "type": "string",
          "pattern": "^[tb]\\d+$"
        },
        "register_space": {
          "type": "string",
          "pattern": "^space\\d+$"
        },
        "num_32bit_values": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "descriptor_table"
              }
            },
            "required": [
              "type"
            ]
          },
          "then": {
            "required": [
              "table"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "cbv"
              }
            },
            "required": [
              "type"
            ]
          },
          "then": {
            "required": [
              "shader_register",
              "register_space"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "root_constants"
              }
            },
            "required": [
              "type"
            ]
          },
          "then": {
            "required": [
              "shader_register",
              "register_space",
              "num_32bit_values"
            ]
          }
        }
      ]
    },
    "d3d12_backend": {
      "type": "object",
      "required": [
        "strategy",
        "root_signature"
      ],
      "properties": {
        "strategy": {
          "type": "object",
          "required": [
            "heaps",
            "tables",
            "domain_realizations"
          ],
          "properties": {
            "heaps": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/d3d12_heap"
              }
            },
            "tables": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/d3d12_table"
              }
            },
            "domain_realizations": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/d3d12_domain_realization"
              }
            }
          },
          "additionalProperties": false
        },
        "root_signature": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/d3d12_root_param"
          }
        }
      },
      "additionalProperties": false
    },
    "vulkan_descriptor_set": {
      "type": "object",
      "required": [
        "id",
        "set"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
        },
        "set": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "vulkan_binding": {
      "type": "object",
      "required": [
        "id",
        "set",
        "binding",
        "descriptor_type"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
        },
        "set": {
          "type": "string"
        },
        "binding": {
          "type": "integer",
          "minimum": 0
        },
        "descriptor_type": {
          "type": "string",
          "enum": [
            "SAMPLED_IMAGE",
            "STORAGE_IMAGE",
            "UNIFORM_TEXEL_BUFFER",
            "STORAGE_TEXEL_BUFFER",
            "UNIFORM_BUFFER",
            "STORAGE_BUFFER",
            "SAMPLER",
            "ACCELERATION_STRUCTURE_KHR"
          ]
        },
        "descriptor_count": {
          "type": "integer",
          "minimum": 1
        },
        "variable_count": {
          "type": "boolean"
        },
        "update_after_bind": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "vulkan_domain_realization": {
      "type": "object",
      "required": [
        "domain",
        "binding",
        "array_element_base"
      ],
      "properties": {
        "domain": {
          "type": "string"
        },
        "binding": {
          "type": "string"
        },
        "array_element_base": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "vulkan_pipeline_entry": {
      "type": "object",
      "required": [
        "type",
        "id"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "descriptor_set",
            "push_constants"
          ]
        },
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
        },
        "set_ref": {
          "type": "string"
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 1
        },
        "stages": {
          "$ref": "#/$defs/vulkan_stage_flags"
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "descriptor_set"
              }
            },
            "required": [
              "type"
            ]
          },
          "then": {
            "required": [
              "set_ref"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "push_constants"
              }
            },
            "required": [
              "type"
            ]
          },
          "then": {
            "required": [
              "size_bytes",
              "stages"
            ]
          }
        }
      ]
    },
    "vulkan_backend": {
      "type": "object",
      "required": [
        "strategy",
        "pipeline_layout"
      ],
      "properties": {
        "strategy": {
          "type": "object",
          "required": [
            "descriptor_sets",
            "bindings",
            "domain_realizations"
          ],
          "properties": {
            "descriptor_sets": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/vulkan_descriptor_set"
              }
            },
            "bindings": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/vulkan_binding"
              }
            },
            "domain_realizations": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/vulkan_domain_realization"
              }
            }
          },
          "additionalProperties": false
        },
        "pipeline_layout": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/vulkan_pipeline_entry"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "examples": [
    {
      "meta": {
        "version": "2.0.0",
        "description": "Authoritative bindless system specification for Oxygen."
      },
      "defaults": {
        "invalid_index": 4294967295
      },
      "abi": {
        "index_spaces": [
          {
            "id": "srv_uav_cbv"
          },
          {
            "id": "sampler"
          }
        ],
        "domains": [
          {
            "id": "srv_global",
            "name": "GlobalSRV",
            "index_space": "srv_uav_cbv",
            "shader_index_base": 1,
            "capacity": 2048,
            "shader_access_class": "buffer_srv",
            "view_types": [
              "StructuredBuffer_SRV"
            ]
          }
        ]
      },
      "backends": {
        "d3d12": {
          "strategy": {
            "heaps": [
              {
                "id": "CBV_SRV_UAV:gpu",
                "type": "CBV_SRV_UAV",
                "shader_visible": true,
                "capacity": 1000000,
                "base_index": 1000000,
                "allow_growth": false
              }
            ],
            "tables": [
              {
                "id": "BindlessSRVTable",
                "descriptor_kind": "SRV",
                "heap": "CBV_SRV_UAV:gpu",
                "shader_register": "t0",
                "register_space": "space0",
                "unbounded": true
              }
            ],
            "domain_realizations": [
              {
                "domain": "srv_global",
                "table": "BindlessSRVTable",
                "heap_local_base": 1
              }
            ]
          },
          "root_signature": [
            {
              "type": "descriptor_table",
              "id": "BindlessSrvTable",
              "table": "BindlessSRVTable",
              "index": 0,
              "visibility": "ALL"
            }
          ]
        },
        "vulkan": {
          "strategy": {
            "descriptor_sets": [
              {
                "id": "bindless_main",
                "set": 0
              }
            ],
            "bindings": [
              {
                "id": "global_buffers_binding",
                "set": "bindless_main",
                "binding": 0,
                "descriptor_type": "STORAGE_BUFFER",
                "variable_count": true,
                "update_after_bind": true
              }
            ],
            "domain_realizations": [
              {
                "domain": "srv_global",
                "binding": "global_buffers_binding",
                "array_element_base": 1
              }
            ]
          },
          "pipeline_layout": [
            {
              "type": "descriptor_set",
              "id": "BindlessMain",
              "set_ref": "bindless_main"
            }
          ]
        }
      }
    }
  ]
}
