<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="Oxygen.Editor.World.Inspector.DirectionalLightView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:DroidNet.Controls"
    xmlns:editorcontrols="using:Oxygen.Editor.Controls"
    xmlns:ui="using:CommunityToolkit.WinUI">

    <editorcontrols:PropertiesExpander
        Padding="2"
        HorizontalAlignment="Stretch"
        HorizontalContentAlignment="Stretch"
        Description="{x:Bind ViewModel.Description, Mode=OneWay}"
        Header="{x:Bind ViewModel.Header, Mode=OneWay}"
        HeaderIcon="{ui:FontIcon Glyph='&#xE706;'}"
        IsExpanded="{x:Bind ViewModel.IsExpanded, Mode=TwoWay}">
        <editorcontrols:PropertiesExpander.Items>
            <editorcontrols:PropertyCard HorizontalContentAlignment="Stretch" PropertyName="Color">
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button
                        MinWidth="44"
                        Padding="4"
                        ToolTipService.ToolTip="Pick light color">
                        <Button.Flyout>
                            <Flyout>
                                <ColorPicker
                                    ColorChanged="ColorPicker_ColorChanged"
                                    IsAlphaEnabled="False"
                                    IsColorChannelTextInputVisible="True"
                                    IsHexInputVisible="True"
                                    Color="{x:Bind ViewModel.ColorValue, Mode=OneWay}" />
                            </Flyout>
                        </Button.Flyout>
                        <Border
                            Width="32"
                            Height="24"
                            Background="{x:Bind ViewModel.ColorBrush, Mode=OneWay}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="2" />
                    </Button>
                    <controls:NumberBox
                        Grid.Column="1"
                        Label="R"
                        LabelPosition="Left"
                        Mask="~.###"
                        NumberValue="{x:Bind ViewModel.ColorR, Mode=TwoWay}" />
                    <controls:NumberBox
                        Grid.Column="2"
                        Label="G"
                        LabelPosition="Left"
                        Mask="~.###"
                        NumberValue="{x:Bind ViewModel.ColorG, Mode=TwoWay}" />
                    <controls:NumberBox
                        Grid.Column="3"
                        Label="B"
                        LabelPosition="Left"
                        Mask="~.###"
                        NumberValue="{x:Bind ViewModel.ColorB, Mode=TwoWay}" />
                </Grid>
            </editorcontrols:PropertyCard>
            <editorcontrols:PropertyCard HorizontalContentAlignment="Stretch" PropertyName="Light">
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <controls:NumberBox
                        Label="Lux"
                        LabelPosition="Left"
                        Mask="~.###"
                        NumberValue="{x:Bind ViewModel.IntensityLux, Mode=TwoWay}" />
                    <controls:NumberBox
                        Grid.Column="1"
                        Label="Angular"
                        LabelPosition="Left"
                        Mask="~.###"
                        NumberValue="{x:Bind ViewModel.AngularSizeRadians, Mode=TwoWay}" />
                </Grid>
            </editorcontrols:PropertyCard>
            <editorcontrols:PropertyCard HorizontalContentAlignment="Stretch" PropertyName="Flags">
                <Grid ColumnSpacing="12" RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ToggleSwitch Header="Sun" IsOn="{x:Bind ViewModel.IsSunLight, Mode=TwoWay}" />
                    <ToggleSwitch
                        Grid.Column="1"
                        Header="Environment"
                        IsOn="{x:Bind ViewModel.EnvironmentContribution, Mode=TwoWay}" />
                    <ToggleSwitch
                        Grid.Row="1"
                        Header="Shadows"
                        IsOn="{x:Bind ViewModel.CastsShadows, Mode=TwoWay}" />
                    <ToggleSwitch
                        Grid.Row="1"
                        Grid.Column="1"
                        Header="Affects World"
                        IsOn="{x:Bind ViewModel.AffectsWorld, Mode=TwoWay}" />
                </Grid>
            </editorcontrols:PropertyCard>
            <editorcontrols:PropertyCard HorizontalContentAlignment="Stretch" PropertyName="Exposure Compensation">
                <controls:NumberBox
                    Label="EV"
                    LabelPosition="Left"
                    Mask="~.###"
                    NumberValue="{x:Bind ViewModel.ExposureCompensation, Mode=TwoWay}" />
            </editorcontrols:PropertyCard>
        </editorcontrols:PropertiesExpander.Items>
    </editorcontrols:PropertiesExpander>
</UserControl>
